@startuml 

title Webserver Design / API Endpoints, example of security API endpoint (as seq diagram)

participant Website
participant EspWifi
participant DmxControllerHttpTask
participant DmxControllerApiServer
participant ApiSecurity
participant EspNowTask
participant NvsTask

Website -> DmxControllerHttpTask : POST Esp  Now Key
DmxControllerHttpTask -> DmxControllerApiServer : POST Esp  Now Key
DmxControllerApiServer -> ApiSecurity : POST Esp Now Key
ApiSecurity -> DmxControllerHttpTask : send key
loop for all nodes
    DmxControllerHttpTask -> EspNowTask : send key
    EspNowTask --> IEspNow : Send Esp Now message
    IEspNow --> EspNowTask : Ack
    EspNowTask --> DmxControllerHttpTask: Ack
end
note over DmxControllerHttpTask
    Wait for all acks
end note
DmxControllerHttpTask -> NvsTask : Store in NVS
NvsTask --> IEspNvs: Store in NVS
IEspNvs --> NvsTask: Ack
NvsTask --> DmxControllerHttpTask : Ack
DmxControllerHttpTask -> DmxControllerApiServer : MakeAckResponse(Ack)
DmxControllerApiServer -> ApiSecurity : MakeResponse(Ack)
ApiSecurity --> DmxControllerApiServer : Ack Response
DmxControllerApiServer --> DmxControllerHttpTask : Ack Response
DmxControllerHttpTask -> 
DmxControllerHttpTask -> Website : Send Response

@enduml 


@startuml 

title Webserver Design / DMX Controller, Get preset Values

actor Website
box "DmxController"
    participant DmxControllerHttpTask <<RtosTask>>
    participant ApiPreset
    participant DmxControllerTask <<RtosTask>>
    participant PresetsTask <<RtosTask>>
    participant DC_EspNowTask <<RtosTask>>
end box
box "Master"
    participant MAS_EspNowTask <<RtosTask>>
    participant MasterTask  <<RtosTask>>
end box 
box "DMX Node"
    participant DMX_EspNowTask <<RtosTask>>
    participant DmxTask <<RtosTask>>
    participant UniversesTask <<RtosTask>>
    participant FileSystemTask <<RtosTask>>
    participant ESP32LittleFs <<ESP32>>
end box

Website -> DmxControllerHttpTask : GET preset_values\n <presetId> 
DmxControllerHttpTask -> ApiPreset : parseRequest()
ApiPreset -> DmxControllerTask : getPresetValues(\n presetId)
DmxControllerTask -> PresetsTask : getPresetValues(\n presetId)
PresetsTask -> DmxControllerTask : getDmxUniverseValues(\n presetId)
DmxControllerTask -> DC_EspNowTask : getDmxUniverseValues(\n universe
DC_EspNowTask -->> MAS_EspNowTask: getDmxUniverseValues(\n From: DmxController, \n universeId)
MAS_EspNowTask -> MasterTask : getDmxUniverseValues(\n From: DmxController, \n universeId)
MasterTask -> MAS_EspNowTask : getDmxUniverseValues(\n To: DmxNode, \n universeId)
MAS_EspNowTask -->> DMX_EspNowTask: getDmxUniverseValues(\n To: DmxNode, \n universeId) 
DMX_EspNowTask -> DmxTask : getDmxUniverseValues(\n universeId)
DmxTask -> UniversesTask: FileSystemTask : getDmxUniverseValues(\n universeId)
UniversesTask -> FileSystemTask : getDmxUniverseValues(\n universeId)
FileSystemTask -> ESP32LittleFs : readFile(universeId)
ESP32LittleFs --> FileSystemTask : fileData

FileSystemTask -> UniversesTask : SendDmxValues(dmxValues)
UniversesTask -> DmxTask : SendDmxValues(dmxValues)
DmxTask -> DMX_EspNowTask : SendDmxValues(dmxValues)
loop 3 packages (max 250 bytes)
    DMX_EspNowTask -->> MAS_EspNowTask: SendDmxValues(\ndmxValues)
end
MAS_EspNowTask -> MAS_EspNowTask : CombineMessages(dmxValue)
DMX_EspNowTask -->> MAS_EspNowTask: SendDmxValues(\n From: DnxNode, \n dmxValues)
MAS_EspNowTask -> MasterTask : SendDmxValues(\n From: DnxNode, \n dmxValues)
MasterTask -> MAS_EspNowTask : SendDmxValues(\nTo: DmxController, \n dmxValues)
loop 3 packages (max 250 bytes)
    MAS_EspNowTask -->> DC_EspNowTask: SendDmxValues(\ndmxValues)
end
DC_EspNowTask -> DC_EspNowTask : CombineMessages(dmxValue)
DC_EspNowTask -> DmxControllerTask : SendDmxValues(\ndmxValues)
DmxControllerTask -> PresetsTask : SendDmxValues(\ndmxValues)
PresetsTask -> DmxControllerTask : SendDmxValuesToServer(\ndmxValues)
DmxControllerTask -> ApiPreset : formatResponse(data)
ApiPreset -> DmxControllerHttpTask : response
DmxControllerHttpTask -> Website : HTTP response



@enduml
