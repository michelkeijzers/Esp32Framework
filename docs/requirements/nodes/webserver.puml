        Creates all objects (DI)
    end note

    class Website <<LittleFS>>

    class DmxControllerHttpTask <<RtosTask>> {}
    Main *-- DmxControllerHttpTask

    class PresetsTask <<RtosTask>> {}
   
    Website <--> DmxControllerHttpTask : REST API
}

package Common 
{
    package RtosTasks
    {
        class RtosTask <<RtosTask>> {}

