@startuml 

title Webserver Design / RTOS Tasks

package Webserver_Package
{
    class Main {}
    note right of Main
        Creates all objects (DI)
    end note

    class Website <<LittleFS>>

    class DmxControllerHttpTask <<RtosTask>> {}
    Main *-- DmxControllerHttpTask

    class PresetsTask <<RtosTask>> {}
   
    Website <--> DmxControllerHttpTask : REST API
}

package Common 
{
    package RtosTasks
    {
        class RtosTask <<RtosTask>> {}

        class HttpTask <<RtosTask>> {}
        note bottom of HttpTask
            Only for
            webservers
            and remotes
        end note        
        class WifiTask <<RtosTask>> {}
        class EspNowTask <<RtosTask>> {}
        class OtaTask <<RtosTask>> {}
        class StatusTask <<RtosTask>> {}
        class NvsTask <<RtosTask>> {}

        HttpTask -u-|> RtosTask
        WifiTask -u-|> RtosTask
        EspNowTask -u-|> RtosTask
        OtaTask -u-|> RtosTask
        StatusTask -u-|> RtosTask
        NvsTask -u-|> RtosTask
        
    }
    package ESP
    {
        class IEspWifi <<ESP32>> {}
        class IEspNow <<ESP32>> {}
        class IEspNvs <<ESP32>> {}
    }

    StatusTask ---> IEspNow
    WifiTask ---> IEspWifi
    EspNowTask ---> IEspNow
    NvsTask ---> IEspNvs
}

DmxControllerHttpTask --|> HttpTask
PresetsTask --|> RtosTask

DmxControllerHttpTask *-- DmxControllerHttpTask
DmxControllerHttpTask *-- PresetsTask
DmxControllerHttpTask *-- StatusTask
DmxControllerHttpTask *-- EspNowTask
DmxControllerHttpTask *-- WifiTask
DmxControllerHttpTask *-- OtaTask
DmxControllerHttpTask *-- NvsTask

@enduml

