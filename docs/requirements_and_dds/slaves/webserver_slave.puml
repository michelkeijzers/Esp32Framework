@startuml 

title Webserver Slave Design / RTOS Tasks

package WebserverSlave_Package
{
    class Main {}
    note right of Main
        Creates all objects (DI)
    end note

    class DmxControllerWebserverSlave <<RtosTask>> {}

    class Website <<LittleFS>>

    class DmxControllerHttpTask <<RtosTask>> {}
    class PresetsTask <<RtosTask>> {}

    Main *--> DmxControllerWebserverSlave
    
    Website <--> DmxControllerHttpTask : REST API
}

package Common 
{
    package RtosTasks
    {
        class RtosTask <<RtosTask>> {}

        class SlaveTask <<RtosTask>> {}
        class HttpTask <<RtosTask>> {}
        note bottom of HttpTask
            Only for
            webserver slaves 
            and remotes
        end note        
        class WifiTask <<RtosTask>> {}
        class EspNowTask <<RtosTask>> {}
        class OtaTask <<RtosTask>> {}
        class StatusTask <<RtosTask>> {}
        class NvsTask <<RtosTask>> {}

        SlaveTask -u-|> RtosTask
        HttpTask -u-|> RtosTask
        WifiTask -u-|> RtosTask
        EspNowTask -u-|> RtosTask
        OtaTask -u-|> RtosTask
        StatusTask -u-|> RtosTask
        NvsTask -u-|> RtosTask
        
    }
    package ESP
    {
        class IEspWifi <<ESP32>> {}
        class IEspNow <<ESP32>> {}
        class IEspNvs <<ESP32>> {}
    }

    StatusTask ---> IEspNow
    WifiTask ---> IEspWifi
    EspNowTask ---> IEspNow
    NvsTask ---> IEspNvs
}

DmxControllerWebserverSlave --|> SlaveTask
DmxControllerHttpTask --|> HttpTask
PresetsTask --|> RtosTask

DmxControllerWebserverSlave *-- DmxControllerHttpTask
DmxControllerWebserverSlave *-- PresetsTask
DmxControllerWebserverSlave *-- StatusTask
DmxControllerWebserverSlave *-- EspNowTask
DmxControllerWebserverSlave *-- WifiTask
DmxControllerWebserverSlave *-- OtaTask
DmxControllerWebserverSlave *-- NvsTask

@enduml

@startuml 

title Webserver Slave Design / API Endpoints, example of security API endpoint 

package WebserverSlave_Package
{
    class Main {}

    class DmxControllerWebserverSlave <<RtosTask>> {}

    class Website <<LittleFS>>

    class DmxControllerHttpTask <<RtosTask>> {}
    class PresetsTask <<RtosTask>> {}

    Main *--> DmxControllerWebserverSlave
    Main *--> DmxControllerHttpTask
    Main *--> PresetsTask

    Website --> DmxControllerHttpTask : 1. POST Esp Now Key
}

package Common 
{
    package Apis 
    {
        class ApiFirmware <<API>> {}
        class ApiLogging <<API>> {}
        class ApiNodes <<API>> {}
        class ApiResposne <<API>> {}
        class ApiSecurity <<API>> {}
        class ApiStatus <<API>> {}
        class ApiSystem <<API>> {}
        class ApiValidator <<API>> {}
        class StaticFileHandler <<API>> {}
    }

    package RtosTasks
    {
        class RtosTask <<RtosTask>> {}

        class SlaveTask <<RtosTask>> {}
        class HttpTask <<RtosTask>> {}
        note bottom of HttpTask
            Only for
            webserver slaves 
            and remotes
        end note        
        class WifiTask <<RtosTask>> {}
        class EspNowTask <<RtosTask>> {}
        class OtaTask <<RtosTask>> {}
        class StatusTask <<RtosTask>> {}
        class NvsTask <<RtosTask>> {}

        SlaveTask -u-|> RtosTask
        HttpTask -u-|> RtosTask
